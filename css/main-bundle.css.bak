@media (max-width: 992px) {
.top-nav {display: none;}
.header-content {flex-direction: column; gap: 20px; text-align: center;}
.right-logos {justify-content: center;}
}

@media (max-width: 1430px) {
.mega-menu {padding: 40px 30px;}
}

@media (max-width: 992px) {
.mega-menu {padding: 15px; display: none; grid-template-columns: 1fr; position: relative;}
.has-mega-menu.active .mega-menu {display: block;}
}

@media (max-width: 992px) {
.nav-links {padding: 10px 0; background-color: var(--primary-color); box-shadow: var(--shadow-lg); display: none; flex-direction: column; left: 0; position: absolute; top: 100%; width: 100%; z-index: 99;}
.nav-links.active {display: flex;}
.nav-links>li {width: 100%;}
.nav-links>li>a {border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding: 12px 20px;}
.hamburger-menu, .dropdown:hover .dropdown-menu,
    .has-mega-menu:hover .mega-menu {display: block;}
.dropdown-menu,
    .mega-menu {border-top: none; background-color: rgba(255, 255, 255, 0.05); box-shadow: none; display: none; opacity: 1; padding-left: 20px; position: static; transform: none; visibility: visible; width: 100%;}
.dropdown-menu li a,
    .mega-column a {color: var(--white);}
.dropdown-menu li a:hover,
    .mega-col a:hover {background-color: rgba(255, 255, 255, 0.1); color: var(--white);}
}

@media (max-width: 992px) {
.quick-links-grid {grid-template-columns: repeat(3, 1fr);}
}

@media (max-width: 576px) {
.quick-links-grid {grid-template-columns: repeat(2, 1fr);}
}

@media (max-width: 1024px) {
.footer-grid {grid-template-columns: repeat(3, 1fr);}
}

@media (max-width: 768px) {
.footer-grid {gap: 30px; grid-template-columns: repeat(2, 1fr);}
.footer-bottom-content {flex-direction: column; gap: 10px; text-align: center;}
}

@media (max-width: 480px) {
.footer-grid {grid-template-columns: 1fr;}
}

@media (max-width: 768px) {
.page-hero-content h1 {font-size: 2rem;}
.glass-card {padding: 20px;}
}

@media (max-width: 992px) {
.page-about .about-grid {gap: 40px; grid-template-columns: 1fr;}
.page-about .about-image {margin: 0 auto; max-width: 500px; order: -1;}
.page-about .img-badge {bottom: -20px; right: 0;}
}

@media (max-width: 768px) {
.page-about .org-chart .node {background: var(--white); border: 2px solid var(--primary-color); padding: 12px 15px; transition: all 0.3s; border-radius: 8px; box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05); color: var(--text-dark); display: inline-block; font-size: 0.9rem; font-weight: 700; max-width: 200px; min-width: 140px; position: relative; text-decoration: none; white-space: normal; z-index: 2;}
}

@media (max-width: 600px) {
.page-about .timeline::before {left: 20px;}
.page-about .timeline-item {flex-direction: row !important;}
.page-about .year {font-size: 1rem; height: 60px; width: 60px;}
.page-about .event {width: calc(100% - 90px);}
}

@media (max-width: 900px) {
.page-about .principal-layout {gap: 40px; grid-template-columns: 1fr;}
.page-about .principal-profile {align-items: center; display: flex; flex-direction: column;}
}

@media (max-width: 768px) {
.page-about .vm-grid {gap: 60px; grid-template-columns: 1fr;}
}

@media (max-width: 768px) {
.page-academics .course-card {align-items: center; flex-direction: column; text-align: center;}
.page-academics .course-meta {justify-content: center;}
}

@media (max-width: 600px) {
