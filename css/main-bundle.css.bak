.about-page-wrapper {grid-template-columns: 1fr;}
.about-sidebar {margin-bottom: 30px; position: static;}
.sidebar-nav {display: grid; gap: 15px; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));}
.sidebar-nav li {margin-bottom: 0;}
}

@media (max-width: 768px) {
.gallery-grid {gap: 20px; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));}
.video-grid {grid-template-columns: 1fr;}
